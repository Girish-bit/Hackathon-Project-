{
  "entities": {
    "Incident": {
      "title": "Security Incident",
      "description": "A detected security threat or system event.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["PHISHING", "MALWARE", "VULNERABILITY", "NETWORK", "IDENTITY", "SYSTEM"] },
        "source": { "type": "string" },
        "description": { "type": "string" },
        "mitigation": { "type": "string" },
        "riskLevel": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "status": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["timestamp", "type", "source", "description", "mitigation", "riskLevel", "status", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/incidents/{incidentId}": {
      "schema": "Incident",
      "description": "Collection of recorded security incidents."
    }
  }
}
