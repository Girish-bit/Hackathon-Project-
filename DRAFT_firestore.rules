rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Incident Validation
    function isValidIncident(data) {
      return data.keys().hasAll(['timestamp', 'type', 'source', 'description', 'riskLevel', 'status', 'authorId', 'createdAt']) &&
             data.keys().size() == 8 &&
             data.timestamp is string &&
             data.type in ['PHISHING', 'MALWARE', 'NETWORK', 'SYSTEM'] &&
             data.source is string && data.source.size() <= 500 &&
             data.description is string && data.description.size() <= 2000 &&
             data.riskLevel in ['LOW', 'MEDIUM', 'HIGH', 'CRITICAL'] &&
             data.status is string && data.status.size() <= 100 &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /incidents/{incidentId} {
      allow create: if isSignedIn() && isValidIncident(incoming());
      allow get: if isOwner(existing().authorId);
      allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
      // No updates or deletes allowed for security audit logs in this implementation
    }
  }
}
