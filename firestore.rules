rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
          data.keys().size() <= 5 &&
          data.uid is string && data.uid == userId &&
          data.email is string && data.email.size() <= 200 &&
          data.role in ['OPERATOR', 'ADMIN'];
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'lastLogin', 'role']);
    }

    // Incident logs
    match /incidents/{incidentId} {
      function isValidIncident(data) {
        return data.keys().hasAll(['timestamp', 'type', 'riskLevel', 'authorId']) &&
          data.timestamp is string &&
          data.type in ['MALWARE', 'PHISHING', 'VULNERABILITY', 'NETWORK', 'IDENTITY'] &&
          data.riskLevel in ['LOW', 'MEDIUM', 'HIGH', 'CRITICAL'] &&
          data.authorId == request.auth.uid;
      }

      allow list: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow create: if isEmailVerified() && isValidIncident(incoming());
      allow update: if false; // Logs are immutable in this version
      allow delete: if false;
    }
  }
}
